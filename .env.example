# Azure App Registration settings for Outlook/Microsoft Graph
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_TENANT_ID=your-azure-tenant-id
# Optional: override the default authority
# AZURE_AUTHORITY=https://login.microsoftonline.com/common

# App-only authentication (recommended for unattended enterprise scheduling)
# AZURE_CLIENT_SECRET=your-azure-app-client-secret
# SERVICE_MAILBOX=service-mailbox@yourdomain.com

# Optional: persistent token cache path for scheduled runs
# TOKEN_CACHE_PATH=token_cache.bin

# Optional: limit total emails fetched (useful for large mailboxes)
# MAX_EMAILS=500
